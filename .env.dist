# ── Discord Bot Token (REQUIRED) ────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Admin IDs (optional, comma-separated Discord user IDs) ──────────
# These users bypass all permission checks (bot-level superadmin)
# ADMIN_IDS=123456789,987654321

# ── Debug Mode (optional) ───────────────────────────────────────────
# DEBUG_MODE=true

# ── Event Creation Defaults (optional, pre-filled in modal) ─────────
# EVENT_DEFAULT_DATE=last_sunday
# EVENT_DEFAULT_TIME=20:00
# EVENT_DEFAULT_REG_START=

# ── Docker Settings ─────────────────────────────────────────────────
PUID=1000
PGID=1000
